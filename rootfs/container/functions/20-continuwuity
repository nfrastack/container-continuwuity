continuwuity_bootstrap_filesystem() {
    create_folder \
                    "${DATA_PATH}, \
                    ${CONFIG_PATH}" \
                    matrix:matrix 750
}

continuwuity_configure_application() {
    case "${LOG_TYPE,,}" in
        file | both )
            create_folder "${LOG_PATH}" matrix:matrix 775
            create_logrotate continuwuity "${LOG_PATH%/}/${LOG_FILE}" matrix matrix
        ;;
    esac

    if [ "${SETUP_TYPE,,}" = "auto" ] ; then
        sanity_var SERVER_NAME "Matrix server name"
    fi
}

__toml_val() {
    local v="$1"
    if [ "$v" = "true" ] || [ "$v" = "false" ]; then echo "$v"
    elif [[ "$v" =~ ^-?[0-9]+(\.[0-9]+)?$ ]]; then echo "$v"
    elif [[ "$v" == \[*\] ]] || [[ "$v" == \{*\} ]]; then echo "$v"
    else
        v="${v//\\/\\\\}"
        v="${v//\"/\\\"}"
        printf '"%s"\n' "$v"
    fi
}

continuwuity_generate_config() {
    if [ "${SETUP_TYPE,,}" != "auto" ] ; then
        return
    fi

    local config="[global]"$'\n'
    local -a pt_entries=()

    for var in "${!CONTINUWUITY_@}"; do
        val="${!var}"
        remainder="${var#CONTINUWUITY_}"
        key=$(echo "$remainder" | tr '[:upper:]' '[:lower:]')

        [ "$remainder" = "LOG_LEVEL" ] && key="log"

        if [[ "$remainder" == *"__"* ]]; then
            local segs=() p="$key"
            while [[ "$p" == *"__"* ]]; do
                segs+=("${p%%__*}")
                p="${p#*__}"
            done
            segs+=("$p")
            key="${segs[-1]}"
            unset 'segs[-1]'
            section=""
            for s in "${segs[@]}"; do
                [ -n "$section" ] && section="${section}." || section=""
                section="${section}${s}"
            done
            case "$section" in
                well_known|proxy) section="global.${section}" ;;
            esac
        else
            section=""
        fi

        pt_entries+=("${section}|${key}=$(__toml_val "$val")")
    done

    if [ ${#pt_entries[@]} -gt 0 ]; then
        IFS=$'\n' pt_sorted=($(sort <<< "${pt_entries[*]}"))
        unset IFS
        current_section=""
        for entry in "${pt_sorted[@]}"; do
            sec="${entry%%|*}"
            kv="${entry#*|}"
            if [ -n "$sec" ] && [ "$sec" != "$current_section" ]; then
                config+=""$'\n'
                config+="[${sec}]"$'\n'
                current_section="$sec"
            fi
            config+="${kv}"$'\n'
        done
    fi

    write_file matrix:matrix@"${CONFIG_PATH%/}/${CONFIG_FILE}":640 <<< "$config"
}
